# Local/generated deck workspaces. Keep repository-owned deck docs and template.
/decks/*
!/decks/README.md
!/decks/_template/
!/decks/_template/**

# Root compatibility local inputs and outputs.
/brief.md
/assets/*
!/assets/.gitkeep
/brand/*
!/brand/*.template.*
/data/*
!/data/.gitkeep
/out/*
!/out/.gitkeep

# Electron desktop app local dependencies and build artifacts.
/apps/desktop/node_modules/
/apps/desktop/dist/
/apps/desktop/release/
