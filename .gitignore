# Local/generated deck workspaces. Keep repository-owned deck docs and template.
/decks/*
!/decks/README.md
!/decks/_template/
!/decks/_template/**

# Legacy root-level deck inputs and outputs. Use decks/<deck_id>/ for new work.
/brief.md
/assets/
/brand/
/data/
/out/

# Local release package output.
/dist/

# JavaScript workspace dependencies and SolidStart intermediate output.
/workbench/node_modules/
/workbench/.output/
/workbench/.vinxi/
