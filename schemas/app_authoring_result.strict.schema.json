{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/slidex.app_authoring_result.strict.schema.json",
  "title": "slidex App Server Authoring Result Strict",
  "type": "object",
  "required": [
    "schemaVersion",
    "stage",
    "status",
    "summary",
    "strategyMarkdown",
    "slideBlueprints",
    "htmlNotes",
    "layoutContract",
    "claimPolicy",
    "risks"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"type": "string", "const": "slidex.appAuthoringResult.v1"},
    "stage": {"type": "string", "enum": ["strategy", "spec", "build_html"]},
    "status": {
      "type": "string",
      "enum": ["pass", "pass_with_risks", "blocked", "user_input_required"]
    },
    "summary": {"type": "string", "minLength": 1},
    "strategyMarkdown": {"type": "string"},
    "slideBlueprints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sectionRole", "headline", "keyMessage", "bodyContent"],
        "additionalProperties": false,
        "properties": {
          "sectionRole": {"type": "string", "minLength": 1},
          "headline": {"type": "string", "minLength": 1},
          "keyMessage": {"type": "string", "minLength": 1},
          "bodyContent": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "evidenceRefs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "claims": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "htmlNotes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "layoutContract": {
      "type": "object",
      "required": ["layoutMode", "panelLabel", "panelText", "primaryColor", "accentColor"],
      "additionalProperties": false,
      "properties": {
        "layoutMode": {"type": "string", "minLength": 1},
        "panelLabel": {"type": "string", "minLength": 1},
        "panelText": {"type": "string", "minLength": 1},
        "primaryColor": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "accentColor": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
      }
    },
    "claimPolicy": {"type": "string", "minLength": 1},
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason", "owner", "expiration", "artifactLink"],
        "additionalProperties": false,
        "properties": {
          "reason": {"type": "string"},
          "owner": {"type": "string"},
          "expiration": {"type": "string"},
          "artifactLink": {"type": "string"}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"stage": {"const": "strategy"}}},
      "then": {"properties": {"strategyMarkdown": {"type": "string", "minLength": 20}}}
    },
    {
      "if": {"properties": {"stage": {"const": "spec"}}},
      "then": {"properties": {"slideBlueprints": {"type": "array", "minItems": 1}}}
    },
    {
      "if": {"properties": {"stage": {"const": "build_html"}}},
      "then": {"properties": {"htmlNotes": {"type": "array", "minItems": 1}}}
    }
  ]
}
