{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/slidex.deck_spec.schema.json",
  "title": "slidex Document Specification",
  "description": "Structured specification for an HTML-first business document rendered to a paginated PDF.",
  "type": "object",
  "required": [
    "metadata",
    "documentType",
    "audience",
    "objective",
    "desiredOutcome",
    "tone",
    "editorialProfile",
    "sourceInventory",
    "intakeStatus",
    "outputContract",
    "renderConfig",
    "pdfConfig",
    "designSystem",
    "editorialDesignPolicy",
    "storyArc",
    "slides",
    "claimProvenance",
    "businessQa",
    "userEditPolicy"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title", "version"],
      "additionalProperties": false,
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "subtitle": {"type": "string"},
        "owner": {"type": "string"},
        "date": {"type": "string"},
        "version": {"type": "string", "minLength": 1},
        "deckId": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
        "activeDeckDir": {"type": "string"},
        "outputDir": {"type": "string"},
        "designGuidanceFile": {"type": "string"},
        "schemaVersion": {"type": "string"},
        "toolName": {"type": "string"},
        "referenceFiles": {
          "type": "array",
          "items": {"$ref": "#/$defs/sourceRef"}
        }
      }
    },
    "documentType": {
      "type": "string",
      "enum": [
        "business_plan",
        "ir_deck",
        "company_profile",
        "proposal",
        "government_grant_plan",
        "executive_report",
        "custom"
      ]
    },
    "audience": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "desiredOutcome": {"type": "string", "minLength": 1},
    "tone": {"type": "string", "minLength": 1},
    "editorialProfile": {
      "type": "object",
      "required": [
        "locale",
        "primaryReader",
        "decisionQuestion",
        "decisionRequirement",
        "requestedDecision",
        "keyConclusion",
        "evidenceMode"
      ],
      "additionalProperties": false,
      "properties": {
        "locale": {"type": "string", "minLength": 2},
        "primaryReader": {"type": "string", "minLength": 1},
        "decisionQuestion": {"type": "string", "minLength": 1},
        "decisionRequirement": {"type": "string", "enum": ["decision", "discussion", "alignment", "information", "custom"]},
        "requestedDecision": {"type": "string", "minLength": 1},
        "keyConclusion": {"type": "string", "minLength": 1},
        "evidenceMode": {"type": "string", "enum": ["sourced", "user_confirmed", "assumption_labeled", "mixed", "blocked_until_sourced"]},
        "notes": {"type": "string"}
      }
    },
    "sourceInventory": {
      "type": "array",
      "items": {"$ref": "#/$defs/sourceRef"}
    },
    "intakeStatus": {
      "type": "object",
      "required": ["status", "questionsAsked", "openQuestions", "approvedAssumptions"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["complete", "incomplete", "blocked", "assumptions_approved"]
        },
        "questionsAsked": {"type": "array", "items": {"type": "string"}},
        "openQuestions": {"type": "array", "items": {"type": "string"}},
        "approvedAssumptions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "outputContract": {
      "type": "object",
      "required": ["sourceHtml", "renderedSlidesDir", "primaryPdf", "renderManifest", "pdfMode", "qaMontage"],
      "additionalProperties": false,
      "properties": {
        "sourceHtml": {"type": "string"},
        "generatedBaselineHtml": {"type": "string"},
        "renderedSlidesDir": {"type": "string"},
        "primaryPdf": {"type": "string"},
        "renderManifest": {"type": "string"},
        "pdfMode": {"type": "string", "enum": ["paginated"]},
        "qaMontage": {"type": "string"},
        "notes": {"type": "string"},
        "qaReport": {"type": "string"},
        "deliverySummary": {"type": "string"}
      }
    },
    "renderConfig": {
      "type": "object",
      "required": ["engine", "slideSelector", "widthPx", "heightPx", "deviceScaleFactor", "waitForFonts", "captureElementOnly"],
      "additionalProperties": false,
      "properties": {
        "engine": {"type": "string", "const": "slidex-cli"},
        "preset": {"type": "string", "enum": ["wide-1080p", "wide-720p", "wide-900p", "wide-1440p", "custom"]},
        "slideSelector": {"type": "string"},
        "widthPx": {"type": "integer", "minimum": 1},
        "heightPx": {"type": "integer", "minimum": 1},
        "deviceScaleFactor": {"type": "number", "exclusiveMinimum": 0},
        "waitForFonts": {"type": "boolean"},
        "captureElementOnly": {"type": "boolean"},
        "fontPreset": {"$ref": "#/$defs/fontPreset"}
      }
    },
    "pdfConfig": {
      "type": "object",
      "required": ["source", "mode", "pageAspectRatio", "pageSizeInches", "imageFit", "background"],
      "additionalProperties": false,
      "properties": {
        "source": {"type": "string", "const": "rendered_images"},
        "mode": {"type": "string", "const": "paginated"},
        "pageAspectRatio": {"type": "string"},
        "pageSizeInches": {
          "type": "object",
          "required": ["width", "height"],
          "additionalProperties": false,
          "properties": {
            "width": {"type": "number", "exclusiveMinimum": 0},
            "height": {"type": "number", "exclusiveMinimum": 0}
          }
        },
        "imageFit": {"type": "string", "enum": ["exact", "contain", "cover"]},
        "background": {"type": "string"}
      }
    },
    "designSystem": {
      "type": "object",
      "required": ["fontPreset", "colors", "typography", "layout", "htmlCssNotes"],
      "additionalProperties": false,
      "properties": {
        "fontPreset": {"$ref": "#/$defs/fontPreset"},
        "fontOverride": {"type": "string"},
        "colors": {"type": "object", "additionalProperties": {"type": "string"}},
        "typography": {"type": "object", "additionalProperties": {"type": "string"}},
        "layout": {"type": "object", "additionalProperties": {"type": "string"}},
        "cssVariables": {"type": "object", "additionalProperties": {"type": "string"}},
        "styleGuidanceSummary": {"type": "string"},
        "styleGuidanceDirectives": {"type": "array", "items": {"type": "string"}},
        "styleGuidanceAvoid": {"type": "array", "items": {"type": "string"}},
        "styleGuidanceConflicts": {"type": "array", "items": {"type": "string"}},
        "htmlCssNotes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "editorialDesignPolicy": {
      "type": "object",
      "required": [
        "aspectRatio",
        "staticHtmlCss",
        "slideSelector",
        "fontPreset",
        "safeMarginPx",
        "gridGutterPx",
        "spacingScalePx",
        "maxTypeSizePx",
        "minBodyFontPx",
        "minCaptionFontPx",
        "contrastNormal",
        "contrastLarge",
        "koreanWrapping",
        "copyLimits",
        "evidencePolicy",
        "sourceFooterPolicy",
        "appendixRelaxationAllowed",
        "accessibilityChecks"
      ],
      "additionalProperties": false,
      "properties": {
        "aspectRatio": {"type": "string", "const": "16:9"},
        "staticHtmlCss": {"type": "boolean", "const": true},
        "slideSelector": {"type": "string", "const": ".slide"},
        "fontPreset": {"$ref": "#/$defs/fontPreset"},
        "safeMarginPx": {"type": "integer", "minimum": 0},
        "gridGutterPx": {"type": "integer", "minimum": 0},
        "spacingScalePx": {"type": "integer", "minimum": 1},
        "maxTypeSizePx": {"type": "integer", "minimum": 1},
        "minBodyFontPx": {"type": "integer", "minimum": 1},
        "minCaptionFontPx": {"type": "integer", "minimum": 1},
        "contrastNormal": {"type": "number", "minimum": 1},
        "contrastLarge": {"type": "number", "minimum": 1},
        "koreanWrapping": {
          "type": "object",
          "required": ["wordBreak", "lineBreak", "hyphenation"],
          "additionalProperties": false,
          "properties": {
            "wordBreak": {"type": "string"},
            "lineBreak": {"type": "string"},
            "hyphenation": {"type": "string"}
          }
        },
        "copyLimits": {
          "type": "object",
          "required": ["headlineChars", "takeawayChars", "maxBullets", "bulletChars", "cjkLineChars"],
          "additionalProperties": false,
          "properties": {
            "headlineChars": {"type": "integer", "minimum": 1},
            "takeawayChars": {"type": "integer", "minimum": 1},
            "maxBullets": {"type": "integer", "minimum": 1},
            "bulletChars": {"type": "integer", "minimum": 1},
            "cjkLineChars": {"type": "integer", "minimum": 1}
          }
        },
        "evidencePolicy": {"type": "string", "enum": ["source_or_user_confirmation_or_assumption", "source_required"]},
        "sourceFooterPolicy": {"type": "string", "enum": ["required_when_claims_or_visuals_present", "always_required", "documented_exception"]},
        "appendixRelaxationAllowed": {"type": "boolean"},
        "accessibilityChecks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "storyArc": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "slides": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/slide"}},
    "claimProvenance": {
      "type": "object",
      "required": ["required", "unsupportedClaimsPolicy", "claims"],
      "additionalProperties": false,
      "properties": {
        "required": {"type": "boolean"},
        "unsupportedClaimsPolicy": {"type": "string", "enum": ["remove_or_rewrite", "mark_as_assumption", "block_until_sourced"]},
        "claims": {"type": "array", "items": {"$ref": "#/$defs/claim"}}
      }
    },
    "businessQa": {
      "type": "object",
      "required": ["documentTypeChecklist", "copyRisks", "evidenceRisks", "legalRisks", "visualRisks"],
      "additionalProperties": false,
      "properties": {
        "documentTypeChecklist": {"type": "array", "items": {"type": "string"}},
        "copyRisks": {"type": "array", "items": {"type": "string"}},
        "evidenceRisks": {"type": "array", "items": {"type": "string"}},
        "legalRisks": {"type": "array", "items": {"type": "string"}},
        "visualRisks": {"type": "array", "items": {"type": "string"}}
      }
    },
    "accessibilityNotes": {"type": "array", "items": {"type": "string"}},
    "htmlImplementationNotes": {"type": "array", "items": {"type": "string"}},
    "candidateOutputComparison": {"type": "array", "items": {"$ref": "#/$defs/candidateOutputComparison"}},
    "userEditPolicy": {
      "type": "object",
      "required": ["allowDirectHtmlEdits", "syncRequiredAfterHtmlEdits", "preserveUserEditsByDefault"],
      "additionalProperties": false,
      "properties": {
        "allowDirectHtmlEdits": {"type": "boolean"},
        "syncRequiredAfterHtmlEdits": {"type": "boolean"},
        "preserveUserEditsByDefault": {"type": "boolean"},
        "baselineHtml": {"type": "string"},
        "syncReport": {"type": "string"},
        "staleDerivativePolicy": {"type": "string"}
      }
    }
  },
  "$defs": {
    "fontPreset": {
      "type": "string",
      "enum": ["pretendard", "noto-sans-kr", "noto-sans-cjk-kr", "ibm-plex-sans-kr", "suit", "custom"]
    },
    "sourceRef": {
      "type": "object",
      "required": ["path", "kind"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "kind": {"type": "string"},
        "role": {"type": "string"},
        "priority": {"type": "string", "enum": ["required", "primary", "supporting", "background"]},
        "notes": {"type": "string"},
        "sha256": {"type": "string"}
      }
    },
    "claim": {
      "type": "object",
      "required": ["id", "text", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "status": {"type": "string", "enum": ["sourced", "user_confirmed", "assumption", "unsupported", "removed"]},
        "material": {"type": "boolean"},
        "claimType": {"type": "string", "enum": ["metric", "outcome", "market", "customer", "security", "compliance", "certification", "comparison", "risk", "qualitative", "other"]},
        "metricMetadata": {"$ref": "#/$defs/metricMetadata"},
        "sourceRefs": {"type": "array", "items": {"type": "string"}},
        "slideIds": {"type": "array", "items": {"type": "string"}},
        "htmlAnchors": {"type": "array", "items": {"type": "string"}},
        "confirmedBy": {"type": "string"},
        "confirmationDate": {"type": "string"},
        "sourceConfidence": {"type": "string", "enum": ["high", "medium", "low", "unknown"]},
        "notes": {"type": "string"}
      }
    },
    "metricMetadata": {
      "type": "object",
      "required": ["unit", "period"],
      "additionalProperties": false,
      "properties": {
        "unit": {"type": "string", "minLength": 1},
        "period": {"type": "string", "minLength": 1},
        "formula": {"type": "string"},
        "sourceRef": {"type": "string"}
      }
    },
    "slide": {
      "type": "object",
      "required": [
        "id",
        "htmlId",
        "sectionRole",
        "slideType",
        "headline",
        "keyMessage",
        "readerQuestion",
        "takeaway",
        "bodyContent",
        "layoutIntent",
        "visualIntent",
        "evidenceRefs",
        "requiredSources",
        "claims",
        "appendix",
        "renderRisks",
        "qaChecks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "htmlId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "sectionRole": {"type": "string"},
        "slideType": {"type": "string", "enum": ["cover", "executive_summary", "decision", "evidence", "chart", "table", "risk", "next_steps", "appendix", "custom"]},
        "headline": {"type": "string", "minLength": 1},
        "keyMessage": {"type": "string", "minLength": 1},
        "readerQuestion": {"type": "string", "minLength": 1},
        "takeaway": {"type": "string", "minLength": 1},
        "bodyContent": {"type": "array", "items": {"type": "string"}},
        "layoutIntent": {"type": "string"},
        "visualIntent": {"type": "string"},
        "evidenceRefs": {"type": "array", "items": {"type": "string"}},
        "requiredSources": {"type": "array", "items": {"type": "string"}},
        "claims": {"type": "array", "items": {"type": "string"}},
        "appendix": {"type": "boolean"},
        "renderRisks": {"type": "array", "items": {"type": "string"}},
        "qaChecks": {"type": "array", "items": {"type": "string"}},
        "speakerNotes": {"type": "string"},
        "accessibilityNotes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "candidateOutputComparison": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "modelOrSource": {"type": "string"},
        "adopt": {"type": "array", "items": {"type": "string"}},
        "adapt": {"type": "array", "items": {"type": "string"}},
        "reject": {"type": "array", "items": {"type": "string"}},
        "sourceFaithfulnessNotes": {"type": "string"}
      }
    }
  }
}
