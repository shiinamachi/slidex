{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/slidex.pending_update.schema.json",
  "title": "slidex Pending Update",
  "type": "object",
  "required": [
    "schemaVersion",
    "toolName",
    "targetVersion",
    "installRoot",
    "stagedRoot",
    "stagedRootManifestSha256",
    "activatorPath",
    "activatorSha256",
    "reason",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "slidex.pendingUpdate.v1"
    },
    "toolName": {
      "type": "string",
      "const": "slidex"
    },
    "targetVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-canary\\.[0-9]{14})?$"
    },
    "targetTag": {
      "type": "string",
      "maxLength": 97,
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(-canary\\.[0-9]{14})?$"
    },
    "installRoot": {
      "type": "string",
      "minLength": 1
    },
    "stagedRoot": {
      "type": "string",
      "minLength": 1
    },
    "stagedRootManifestSha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "activatorPath": {
      "type": "string"
    },
    "activatorSha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "activationCommand": {
      "type": "string"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    }
  }
}
